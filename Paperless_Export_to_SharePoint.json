    {
      "parameters": {
        "jsCode": "// ============================================\n// SharePoint Pfad aus Paperless-Tags aufbauen\n// Gleiche Logik wie V11 Mail-Workflow\n// ============================================\nconst docInfo = $('Extract Document Info').first().json;\nconst allTagsResponse = $('Get All Tags (for mapping)').first().json;\n\n// Tag-ID zu Name Mapping\nconst tagMap = {};\nallTagsResponse.results.forEach(tag => {\n  tagMap[tag.id] = tag.name;\n});\n\n// Tag-Namen ermitteln, 'Fertig' rausfiltern\nconst tagNames = docInfo.doc_tags\n  .map(tagId => tagMap[tagId])\n  .filter(name => name && name !== 'Fertig');\n\nif (tagNames.length === 0) {\n  tagNames.push('Sonstige');\n}\n\n// Ordnerpfad (relativ unter DMS/Archiv/Paperless/)\nconst folderPath = tagNames.join('/');\n\n// Dateiname säubern (keine Sonderzeichen die SharePoint nicht mag)\nconst safeTitle = docInfo.doc_title\n  .replace(/[<>:\"\\/\\\\|?*#%]/g, '_')\n  .trim();\nconst fileName = safeTitle + '.pdf';\n\n// SharePoint REST API Pfade (identisches Muster wie V11)\nconst siteBase = 'https://YOUR_TENANT.sharepoint.com/sites/YOUR_SITE';\nconst serverRelativeFolder = `/sites/YOUR_SITE/YOUR_SHAREPOINT_BASE_PATH/Paperless/${folderPath}`;\n\n// URL-encoded Ordnerpfad für API-Aufrufe\nconst encodedFolder = serverRelativeFolder.replace(/ /g, '%20');\n\nconst folderCreateUrl = `${siteBase}/_api/web/folders/add('${encodedFolder}')`;\nconst uploadUrl = `${siteBase}/_api/web/GetFolderByServerRelativeUrl('${encodedFolder}')/Files/add(url='${encodeURIComponent(fileName)}',overwrite=true)`;\n\nreturn {\n  json: {\n    doc_id: docInfo.doc_id,\n    doc_title: docInfo.doc_title,\n    tag_names: tagNames,\n    folder_path: folderPath,\n    file_name: fileName,\n    folder_create_url: folderCreateUrl,\n    upload_url: uploadUrl,\n    server_relative_folder: serverRelativeFolder\n  }\n};"
      },
      "id": "cf1733c2-7358-41ff-a0c4-ed30c0d5c973",
