      "id": "3d281b72-99c6-461f-a2d5-c4c7c29d36f8",
      "name": "Get All Tags (for mapping)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        -3456,
        704
      ],
      "credentials": {
        "httpHeaderAuth": {
