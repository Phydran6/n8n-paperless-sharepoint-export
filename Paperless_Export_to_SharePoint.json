    {
      "parameters": {
        "jsCode": "const info = $('Build SharePoint Path').first().json;\nconst input = $input.first().json;\n\nconst erfolg = !input.fehler;\nconst icon = erfolg ? '✅' : '❌';\nconst aktion = erfolg\n  ? 'Aus Paperless gelöscht und nach SharePoint verschoben'\n  : 'NICHT verschoben – verbleibt in Paperless';\n\nconst zeilen = [\n  '═══════════════════════════════════════════════',\n  `${icon}  PAPERLESS EXPORT ABGESCHLOSSEN`,\n  '═══════════════════════════════════════════════',\n  '',\n  `📄 Dokument :  ${info.doc_title}`,\n  `🔖 Tags     :  ${info.tag_names.join(', ')}`,\n  '',\n  `📁 Zielordner: DMS/Archiv/Paperless/${info.folder_path}`,\n  `📎 Dateiname : ${info.file_name}`,\n  '',\n  `🔄 Aktion   :  ${aktion}`,\n  ...(erfolg ? [] : [`⚠️  Fehler   :  ${input.fehler}`]),\n  '',\n  '═══════════════════════════════════════════════',\n];\n\nconst zusammenfassung = zeilen.join('\\n');\nconsole.log(zusammenfassung);\n\nreturn [{\n  json: {\n    zusammenfassung,\n    doc_id: info.doc_id,\n    doc_title: info.doc_title,\n    ziel: `DMS/Archiv/Paperless/${info.folder_path}/${info.file_name}`,\n    erfolg\n  }\n}];"
      },
